# Weekend Casino — Environment Variables
# Copy this to .env and fill in your values

# Server environment
NODE_ENV=development

# CORS — comma-separated allowed origins for production
# ALLOWED_ORIGINS=https://your-production-domain.com,https://your-other-domain.com

# Redis — persistence backend for production
# REDIS_URL=redis://localhost:6379

# Deepgram STT (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Meshy AI (3D Model Generation)
MESHY_API_KEY=your_meshy_api_key_here

# ElevenLabs TTS (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
VOX_LAMBDA_ARN=your_vox_lambda_arn_here

# Controller URL (production — used for QR code on TV display)
# VITE_CONTROLLER_URL=https://controller.your-domain.com
