# VGF game server URL
VITE_SERVER_URL=http://localhost:3000

# Game identifier for Platform SDK
VITE_GAME_ID=weekend-casino

# Platform SDK stage: local | test | dev | staging | production
VITE_PLATFORM_SDK_STAGE=local

# Segment analytics write key (optional — leave blank for dev)
VITE_SEGMENT_WRITE_KEY=

# Datadog RUM (optional — leave blank for dev)
VITE_DD_APPLICATION_ID=
VITE_DD_CLIENT_TOKEN=
